<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <description>Before-save: stamps Tag_Key__c = LOWER(Name)+'|'+Category so the unique, case-insensitive Tag_Key__c enforces per-category dedupe for every entry path (LWC, data import, manual). JSI-122. Author: Jason Ott.</description>
    <environments>Default</environments>
    <formulas>
        <name>TagKeyFormula</name>
        <dataType>String</dataType>
        <expression>LOWER(TRIM({!$Record.Name})) &amp; "|" &amp; TEXT({!$Record.Category__c})</expression>
    </formulas>
    <interviewLabel>Tag - Set Tag Key (Before Save) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Tag - Set Tag Key (Before Save)</label>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Tag_Key</targetReference>
        </connector>
        <object>Tag__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <assignments>
        <name>Set_Tag_Key</name>
        <label>Set Tag Key</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>$Record.Tag_Key__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>TagKeyFormula</elementReference>
            </value>
        </assignmentItems>
    </assignments>
</Flow>
