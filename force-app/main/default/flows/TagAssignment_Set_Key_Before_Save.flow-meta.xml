<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <description>Before-save: stamps Assignment_Key__c = Tag + '|' + (Contact or Account) so the unique Assignment_Key__c prevents the same tag being applied twice to one record, for every entry path. JSI-122. Author: Jason Ott.</description>
    <environments>Default</environments>
    <formulas>
        <name>AssignmentKeyFormula</name>
        <dataType>String</dataType>
        <expression>{!$Record.Tag__c} &amp; "|" &amp; IF(ISBLANK({!$Record.Contact__c}), {!$Record.Account__c}, {!$Record.Contact__c})</expression>
    </formulas>
    <interviewLabel>Tag Assignment - Set Key (Before Save) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Tag Assignment - Set Key (Before Save)</label>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Assignment_Key</targetReference>
        </connector>
        <object>Tag_Assignment__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <assignments>
        <name>Set_Assignment_Key</name>
        <label>Set Assignment Key</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>$Record.Assignment_Key__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>AssignmentKeyFormula</elementReference>
            </value>
        </assignmentItems>
    </assignments>
</Flow>
