<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amount_Not_Negative</fullName>
    <active>true</active>
    <description>A credited amount cannot be negative. JSI-90 / Jason Ott.</description>
    <errorConditionFormula>Amount__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Amount__c</errorDisplayField>
    <errorMessage>Amount cannot be negative.</errorMessage>
</ValidationRule>
