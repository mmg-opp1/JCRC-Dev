<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>One summary record per Contact per CC email: opened/clicked flags, counts, and dates. Kept current each poll (not one row per event). Child (lookup) of CC_Email__c and Contact. JSI-109 / Jason Ott.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>CC Email Activity</label>
    <nameField>
        <displayFormat>EA-{000000}</displayFormat>
        <label>Activity Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>CC Email Activities</pluralLabel>
    <sharingModel>Read</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
