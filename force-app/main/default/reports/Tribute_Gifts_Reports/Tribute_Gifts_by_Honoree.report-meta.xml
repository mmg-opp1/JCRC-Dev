<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Tribute Gifts by Honoree</name>
    <description>Tribute/memorial gifts grouped by honoree (Honoree Contact). Honoree Name column surfaces text-only honorees not yet matched to a contact. Filtered to gifts with a Tribute Type. JSI-89 / Jason Ott.</description>
    <reportType>Opportunity</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Opportunity.npsp__Honoree_Contact__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>OPPORTUNITY_NAME</field>
    </columns>
    <columns>
        <field>ACCOUNT_NAME</field>
    </columns>
    <columns>
        <field>Opportunity.npsp__Tribute_Type__c</field>
    </columns>
    <columns>
        <field>Opportunity.npsp__Honoree_Name__c</field>
    </columns>
    <columns>
        <field>AMOUNT</field>
        <aggregateTypes>Sum</aggregateTypes>
    </columns>
    <columns>
        <field>CLOSE_DATE</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Opportunity.npsp__Tribute_Type__c</column>
            <operator>notEqual</operator>
            <value></value>
        </criteriaItems>
    </filter>
</Report>
