<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Pledge Payments Due This Fiscal Year</name>
    <description>Scheduled, unpaid pledge/grant installments due in the current fiscal year (cash-flow forecast). JSI-82 / Jason Ott.</description>
    <reportType>Pledges_with_Payments__c</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Month</dateGranularity>
        <field>Opportunity.npe01__OppPayment__r$npe01__Scheduled_Date__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>Opportunity$Name</field>
    </columns>
    <columns>
        <field>Opportunity$StageName</field>
    </columns>
    <columns>
        <field>Opportunity.npe01__OppPayment__r$npe01__Payment_Amount__c</field>
        <aggregateTypes>Sum</aggregateTypes>
    </columns>
    <columns>
        <field>Opportunity.npe01__OppPayment__r$npe01__Paid__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Opportunity$StageName</column>
            <operator>equals</operator>
            <value>Pledged</value>
        </criteriaItems>
        <criteriaItems>
            <column>Opportunity.npe01__OppPayment__r$npe01__Paid__c</column>
            <operator>equals</operator>
            <value>false</value>
        </criteriaItems>
        <criteriaItems>
            <column>Opportunity.npe01__OppPayment__r$npe01__Written_Off__c</column>
            <operator>equals</operator>
            <value>false</value>
        </criteriaItems>
    </filter>
    <timeFrameFilter>
        <dateColumn>Opportunity.npe01__OppPayment__r$npe01__Scheduled_Date__c</dateColumn>
        <interval>INTERVAL_CURFY</interval>
    </timeFrameFilter>
</Report>
