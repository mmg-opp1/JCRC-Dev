<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>In-Kind Gifts by Type</name>
    <description>In-kind (non-cash) gifts grouped by In-Kind Type, valued at Fair Market Value. In-kind gifts are excluded from donor cash rollups; this report uses FMV (Amount is left blank). JSI-84 / Jason Ott.</description>
    <reportType>Opportunity</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Opportunity.npsp__In_Kind_Type__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>ACCOUNT_NAME</field>
    </columns>
    <columns>
        <field>OPPORTUNITY_NAME</field>
    </columns>
    <columns>
        <field>CLOSE_DATE</field>
    </columns>
    <columns>
        <field>Opportunity.npsp__Fair_Market_Value__c</field>
        <aggregateTypes>Sum</aggregateTypes>
    </columns>
    <columns>
        <field>Opportunity.npsp__In_Kind_Description__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>RECORDTYPE</column>
            <operator>equals</operator>
            <value>Opportunity.In_Kind_Gift</value>
        </criteriaItems>
    </filter>
</Report>
