<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <name>Securities Gifts (This Fiscal Year)</name>
    <description>Stock/securities gifts recorded this fiscal year, with valuation detail (shares, ticker, date received, method) and liquidated Amount. JSI-84 / Jason Ott.</description>
    <reportType>Opportunity</reportType>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>ACCOUNT_NAME</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <columns>
        <field>OPPORTUNITY_NAME</field>
    </columns>
    <columns>
        <field>CLOSE_DATE</field>
    </columns>
    <columns>
        <field>AMOUNT</field>
        <aggregateTypes>Sum</aggregateTypes>
    </columns>
    <columns>
        <field>Opportunity.Number_of_Shares__c</field>
    </columns>
    <columns>
        <field>Opportunity.Stock_Ticker_Symbol__c</field>
    </columns>
    <columns>
        <field>Opportunity.Date_Stock_Received__c</field>
    </columns>
    <columns>
        <field>Opportunity.Stock_Valuation_Method__c</field>
    </columns>
    <columns>
        <field>Opportunity.Deductible_Amount__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>RECORDTYPE</column>
            <operator>equals</operator>
            <value>Opportunity.Securities_Gift</value>
        </criteriaItems>
    </filter>
    <timeFrameFilter>
        <dateColumn>CLOSE_DATE</dateColumn>
        <interval>INTERVAL_CURFY</interval>
    </timeFrameFilter>
</Report>
