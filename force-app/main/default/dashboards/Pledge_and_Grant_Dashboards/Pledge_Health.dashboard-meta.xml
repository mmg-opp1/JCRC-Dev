<?xml version="1.0" encoding="UTF-8"?>
<Dashboard xmlns="http://soap.sforce.com/2006/04/metadata">
    <backgroundEndColor>#FFFFFF</backgroundEndColor>
    <backgroundFadeDirection>Diagonal</backgroundFadeDirection>
    <backgroundStartColor>#FFFFFF</backgroundStartColor>
    <dashboardType>SpecifiedUser</dashboardType>
    <leftSection>
        <columnSize>Medium</columnSize>
        <components>
            <componentType>Metric</componentType>
            <footer>Remaining Balance on active pledges/grants</footer>
            <header>Total Outstanding</header>
            <indicatorHighColor>#54C254</indicatorHighColor>
            <indicatorLowColor>#C25454</indicatorLowColor>
            <indicatorMiddleColor>#D9A741</indicatorMiddleColor>
            <metricLabel>Outstanding</metricLabel>
            <report>Pledge_and_Grant_Reports/Outstanding_Pledges</report>
            <title>Total Outstanding Pledges</title>
        </components>
        <components>
            <chartAxisRange>Auto</chartAxisRange>
            <componentType>Donut</componentType>
            <enableHover>true</enableHover>
            <footer>By lifecycle stage</footer>
            <header>Pledges by Stage</header>
            <legendPosition>Right</legendPosition>
            <report>Pledge_and_Grant_Reports/Pledges_by_Lifecycle_Stage</report>
            <sortBy>RowValueDescending</sortBy>
            <title>Pledges by Lifecycle Stage</title>
        </components>
    </leftSection>
    <rightSection>
        <columnSize>Medium</columnSize>
        <components>
            <chartAxisRange>Auto</chartAxisRange>
            <componentType>Column</componentType>
            <enableHover>true</enableHover>
            <footer>Amount past due by owner</footer>
            <header>Overdue Pledges</header>
            <report>Pledge_and_Grant_Reports/Overdue_Pledges</report>
            <sortBy>RowValueDescending</sortBy>
            <title>Overdue by Owner</title>
        </components>
        <components>
            <chartAxisRange>Auto</chartAxisRange>
            <componentType>Bar</componentType>
            <enableHover>true</enableHover>
            <footer>Written off / partially posted</footer>
            <header>Pledge Write-Offs</header>
            <report>Pledge_and_Grant_Reports/Pledge_Write_Offs</report>
            <sortBy>RowValueDescending</sortBy>
            <title>Write-Offs (Bad Debt)</title>
        </components>
    </rightSection>
    <runningUser>jcrcny@missionmattersgroup.com.dev</runningUser>
    <textColor>#000000</textColor>
    <title>Pledge Health</title>
    <titleColor>#000000</titleColor>
    <titleSize>12</titleSize>
</Dashboard>
